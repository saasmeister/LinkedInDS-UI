{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app/**",
              "components/content/**",
              "components/icons/**",
              "components/illustration/**",
              "components/layout/**",
              "components/preview/**",
              "components/text/**",
              "tools/**",
              "tools/anti-slop/**",
              "ui_kits/setup/**",
              "ui_kits/update-center/**",
              "ui_kits/visual-library/**",
              "uploads/Design system setup/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrowserMock'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|cta|emphasis|tone|children|style|key|ref|className|style|children)$/]",
        "message": "<BrowserMock> doesn't accept that prop. Declared props: title, cta, emphasis, tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrowserMock'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|section)$/]",
        "message": "<BrowserMock> tone must be one of 'light' | 'section'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Canvas'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|margin|density|scale|children|style|key|ref|className|style|children)$/]",
        "message": "<Canvas> doesn't accept that prop. Declared props: role, margin, density, scale, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Canvas'] > JSXAttribute[name.name='density'] > Literal[value!=/^(?:default|tight)$/]",
        "message": "<Canvas> density must be one of 'default' | 'tight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chrome'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|category|position|swipe|inset|style|key|ref|className|style|children)$/]",
        "message": "<Chrome> doesn't accept that prop. Declared props: name, category, position, swipe, inset, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chrome'] > JSXAttribute[name.name='position'] > Literal[value!=/^(?:top|bottom)$/]",
        "message": "<Chrome> position must be one of 'top' | 'bottom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Cta'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Cta> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeedAuthor'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|headline|link|avatar|time|key|ref|className|style|children)$/]",
        "message": "<FeedAuthor> doesn't accept that prop. Declared props: name, headline, link, avatar, time."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|heading|body|emphasis|number|children|style|key|ref|className|style|children)$/]",
        "message": "<InfoCard> doesn't accept that prop. Declared props: label, heading, body, emphasis, number, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|style|key|ref|className|style|children)$/]",
        "message": "<Quote> doesn't accept that prop. Declared props: children, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|caption|size|align|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, caption, size, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|xl)$/]",
        "message": "<Stat> size must be one of 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<Stat> align must be one of 'center' | 'left'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "BrowserMock": {
        "replaces": []
